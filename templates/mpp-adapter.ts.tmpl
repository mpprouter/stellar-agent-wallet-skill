/**
 * @stellar/mpp charge-mode envelope adapter.
 *
 * Uses the official @stellar/mpp/charge/client directly — it already handles
 * the mppx Credential envelope and DID/challenge binding. We just route
 * through the same env-based config as the x402 adapter for consistency.
 *
 * Requires: @stellar/mpp mppx
 */

import "dotenv/config";
import { stellar } from "@stellar/mpp/charge/client";
import { Mppx } from "mppx/client";

/**
 * Build an mppx client configured with the Stellar charge method.
 * Call `.fetch(url)` on the returned client to transparently handle
 * 402 responses from MPP servers.
 */
export function createMppClient() {
  const secret = process.env.STELLAR_SECRET;
  const network = (process.env.STELLAR_NETWORK ?? "pubnet") as
    | "testnet"
    | "pubnet";
  const rpcUrl =
    process.env.STELLAR_RPC_URL ??
    (network === "pubnet"
      ? "https://mainnet.sorobanrpc.com"
      : "https://soroban-testnet.stellar.org");

  if (!secret) {
    throw new Error(
      "STELLAR_SECRET is required. Copy .env.example to .env and fill it in.",
    );
  }

  return new Mppx({
    methods: [
      stellar.charge({
        secret,
        network: `stellar:${network}`,
        rpcUrl,
        // feePayer: true is the sponsored path — the ONLY path that is
        // also compatible with x402. Do not flip this off unless you
        // only care about MPP servers.
        feePayer: true,
      }),
    ],
  });
}
