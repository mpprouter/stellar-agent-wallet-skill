# Stellar agent wallet — client config
# Copy to .env and fill in values. NEVER commit .env.
#
# ⚠️  DEFAULT NETWORK IS PUBNET (MAINNET / REAL MONEY).
# If STELLAR_NETWORK is unset, every transaction moves real USDC.
# To prototype safely, set STELLAR_NETWORK=testnet below.

# ─── Network ─────────────────────────────────────────────────────────────
# "testnet" for dev, "pubnet" for mainnet (REAL MONEY — this is the default).
# Read references/mainnet-checklist.md before running on pubnet.
STELLAR_NETWORK=pubnet

# Your Stellar secret key (S...). Required.
# ⚠️  This is a WALLET PRIVATE KEY. Use a dedicated hot wallet, not your main.
# Generate one: npx tsx scripts/generate-keypair.ts
STELLAR_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── RPC ─────────────────────────────────────────────────────────────────
# Soroban RPC URL. Testnet can use the public one; mainnet should NOT.
# Testnet:  https://soroban-testnet.stellar.org
# Mainnet:  https://mainnet.sorobanrpc.com  (get a provider — public RPCs rate-limit)
STELLAR_RPC_URL=https://mainnet.sorobanrpc.com

# Horizon URL — used by check-balance for Classic balances and trustlines.
# Testnet:  https://horizon-testnet.stellar.org
# Mainnet:  https://horizon.stellar.org
STELLAR_HORIZON_URL=https://horizon.stellar.org

# ─── Asset ───────────────────────────────────────────────────────────────
# Default SAC asset address (USDC on chosen network).
# Testnet USDC: CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA
# Mainnet USDC: CCW67TSZV3SSS2HXMBQ5JFGCKJNXKZM7UQUWUZPUTHXSTZLEO7SJMI75
STELLAR_ASSET_SAC=CCW67TSZV3SSS2HXMBQ5JFGCKJNXKZM7UQUWUZPUTHXSTZLEO7SJMI75

# ─── Optional: MPP Router discovery ──────────────────────────────────────
# Base URL of the MPP Router catalog API. Leave as default unless self-hosted.
MPP_ROUTER_URL=https://apiserver.mpprouter.dev

# ─── Optional: Rozo cross-chain intents ──────────────────────────────────
# Base URL of the Rozo intent API (used by send-payment + bridge sub-skills).
# No API key required — public + rate-limited. Mainnet only.
ROZO_INTENT_URL=https://intentapiv4.rozo.ai/functions/v1/payment-api
