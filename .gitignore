# Secrets
.env
.env.local
.env.*.local
.stellar-secret
*.stellar-secret
stellar.key
*.key
docs


# Dependencies (this is a skill package — no deps expected, but guard anyway)
node_modules/
pnpm-lock.yaml
package-lock.json
yarn.lock

# Allow package-lock.json inside the published plugin build so that
# Claude Code can run `npm install` deterministically after cloning.
!build/plugin/**/package-lock.json

# Build output
dist/
*.tsbuildinfo

# build/skill/  — local convenience output, regenerable, uploaded manually
#                 to the skill marketplace. Not committed.
# build/plugin/ — PUBLISHED plugin artifact, referenced by the repo-root
#                 .claude-plugin/marketplace.json via git-subdir source.
#                 COMMITTED to git so users can install via
#                 /plugin marketplace add mpprouter/stellar-agent-wallet-skill
build/skill/

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
